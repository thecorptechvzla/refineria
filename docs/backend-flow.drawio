  <diagram id="page-db" name="Modelo de Datos">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" fold="1" page="1" pageScale="1" pageWidth="1200" height="900" math="0" shadow="0">
      <root>
        <mxCell id="d0" /><mxCell id="d1" parent="d0" />
        <mxCell id="d-title" value="&lt;b&gt;MODELO DE DATOS — PRISMA SCHEMA&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="d1"><mxGeometry x="40" y="10" width="1120" height="30" as="geometry" /></mxCell>
        <mxCell id="d-users" value="&lt;b&gt;users&lt;/b&gt;&lt;hr&gt;id: String (UUID PK) 🔑&#xa;name: String&#xa;email: String (UNIQUE)&#xa;password: String (bcrypt)&#xa;role: Role [ADMIN | SUPERADMIN]&#xa;created_at: DateTime&#xa;updated_at: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="d1"><mxGeometry x="80" y="80" width="250" height="160" as="geometry" /></mxCell>
        <mxCell id="d-suppliers" value="&lt;b&gt;suppliers&lt;/b&gt;&lt;hr&gt;id: String (UUID PK) 🔑&#xa;name: String&#xa;contact_info: String&#xa;registration_date: DateTime&#xa;created_at: DateTime&#xa;updated_at: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="d1"><mxGeometry x="460" y="80" width="250" height="150" as="geometry" /></mxCell>
        <mxCell id="d-transactions" value="&lt;b&gt;transactions&lt;/b&gt;&lt;hr&gt;id: String (UUID PK) 🔑&#xa;type: TransactionType [IN | OUT]&#xa;weight: Float&#xa;weight_unit: WeightUnit [g | kg]&#xa;purity: Float&#xa;&lt;b&gt;supplier_id: String? (FK) 🔗&lt;/b&gt;&#xa;date: DateTime&#xa;created_at: DateTime&#xa;updated_at: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="d1"><mxGeometry x="460" y="320" width="250" height="200" as="geometry" /></mxCell>
        <mxCell id="d-workers" value="&lt;b&gt;workers&lt;/b&gt;&lt;hr&gt;id: String (UUID PK) 🔑&#xa;name: String&#xa;position: String&#xa;status: WorkerStatus [active | inactive]&#xa;start_date: DateTime&#xa;created_at: DateTime&#xa;updated_at: DateTime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="d1"><mxGeometry x="80" y="320" width="250" height="170" as="geometry" /></mxCell>
        <mxCell id="d-enums" value="&lt;b&gt;Enums&lt;/b&gt;&lt;hr&gt;• Role: ADMIN, SUPERADMIN&#xa;• TransactionType: IN, OUT&#xa;• WeightUnit: g, kg&#xa;• WorkerStatus: active, inactive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="d1"><mxGeometry x="80" y="550" width="250" height="100" as="geometry" /></mxCell>
        <mxCell id="d-seed" value="&lt;b&gt;Seed Data (prisma/seed.ts)&lt;/b&gt;&lt;hr&gt;2 usuarios (admin, dueño)&#xa;6 proveedores mineros&#xa;21 transacciones (2024-2025)&#xa;8 trabajadores (6 activos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="d1"><mxGeometry x="460" y="550" width="250" height="110" as="geometry" /></mxCell>
        <mxCell id="" value="FK: supplier_id → suppliers.id&#xa;1 → N | ON DELETE SET NULL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;strokeColor=#82b366;" edge="1" parent="d1" source="d-suppliers" target="d-transactions"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
