  <diagram id="page-auth" name="Flujo de Autenticación">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="a0" /><mxCell id="a1" parent="a0" />
        <mxCell id="a-title" value="&lt;b&gt;SECUENCIA DE AUTENTICACIÓN&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="a1"><mxGeometry x="40" y="10" width="1120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-col-browser" value="&lt;b&gt;🌐 Navegador&lt;/b&gt;" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.rect;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=1;fontSize=12;" vertex="1" parent="a1"><mxGeometry x="60" y="80" width="160" height="780" as="geometry" /></mxCell>
        <mxCell id="a-col-next" value="&lt;b&gt;⚡ Next.js rewrite / proxy&lt;/b&gt;" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.rect;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=12;" vertex="1" parent="a1"><mxGeometry x="420" y="80" width="160" height="780" as="geometry" /></mxCell>
        <mxCell id="a-col-back" value="&lt;b&gt;🖥️ NestJS Backend&lt;/b&gt;" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.rect;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=12;" vertex="1" parent="a1"><mxGeometry x="780" y="80" width="160" height="780" as="geometry" /></mxCell>
        <mxCell id="a-step1" value="1. GET /login (sin cookie)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="80" y="120" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step1a" value="proxy.ts: no cookie → permite /login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="440" y="120" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="" value="GET /login" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step1" target="a-step1a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a-step2" value="2. POST /auth/login&#xa;{email, password}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="80" y="210" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step2a" value="Rewrite /api/auth/login&#xa;→ :4000/auth/login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="440" y="210" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step2b" value="AuthController.login()&#xa;Valida email+password&#xa;Genera JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="800" y="210" width="120" height="50" as="geometry" /></mxCell>
        <mxCell id="" value="POST" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step2" target="a-step2a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step2a" target="a-step2b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a-step3b" value="Responde: {token, user}&#xa;+ Set-Cookie httpOnly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="800" y="310" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step3a" value="Forwardea respuesta +&#xa;Set-Cookie al browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="440" y="310" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step3" value="3. localStorage.setItem&#xa;setAuthToken(res.token)&#xa;setUser(res.user)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="80" y="310" width="120" height="50" as="geometry" /></mxCell>
        <mxCell id="" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step2b" target="a-step3a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="" value="{token, user} + Set-Cookie" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step3a" target="a-step3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a-step4" value="4. router.push('/')&#xa;navegación cliente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="80" y="410" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step4a" value="proxy.ts: cookie existe → permite&#xa;ADMIN → /transacciones" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="440" y="410" width="120" height="55" as="geometry" /></mxCell>
        <mxCell id="" value="client nav" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step4" target="a-step4a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a-step5" value="5. GET /auth/profile&#xa;(GoldContext)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="80" y="520" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step5a" value="Rewrite /api/auth/profile&#xa;Authorization: Bearer token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="440" y="520" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step5b" value="JwtStrategy.validate()&#xa;Busca user por sub&#xa;Retorna user (no pass)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="800" y="520" width="120" height="50" as="geometry" /></mxCell>
        <mxCell id="" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step5" target="a-step5a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="" value="Bearer" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step5a" target="a-step5b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="" value="{user}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step5b" target="a-step5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a-step6" value="6. Cerrar Sesión" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="80" y="630" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step6a" value="POST /api/auth/logout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="440" y="630" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step6b" value="AuthController.logout()&#xa;Set-Cookie: maxAge=0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="800" y="630" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step6" target="a-step6a"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step6a" target="a-step6b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a-step7" value="7. window.location = /login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="80" y="730" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a-step7a" value="proxy.ts: no cookie → redirige" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="440" y="730" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="" value="setAuthToken(null) + hard redirect" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" parent="a1" source="a-step7" target="a-step7a"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page-routes" name="Rutas API">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="r0" /><mxCell id="r1" parent="r0" />
        <mxCell id="r-title" value="&lt;b&gt;RUTAS API Y CONTROL DE ACCESO&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#1a1a2e;fontStyle=1;" vertex="1" parent="r1"><mxGeometry x="40" y="10" width="1120" height="30" as="geometry" /></mxCell>
        <mxCell id="r-legend" value="&lt;b&gt;Colores por método HTTP:&lt;/b&gt;&lt;hr&gt;🟢 GET = Obtener&#xa;🟡 POST = Crear&#xa;🔵 PATCH = Actualizar&#xa;🔴 DELETE = Eliminar&#xa;⚪ Sin fondo = Público" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;" vertex="1" parent="r1"><mxGeometry x="40" y="60" width="200" height="140" as="geometry" /></mxCell>
