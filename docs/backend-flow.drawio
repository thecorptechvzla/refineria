        <mxCell id="" value="GET /:id → Obtener uno" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="320" y="360" width="300" height="30" as="geometry" /></mxCell>
