        <mxCell id="" value="DELETE /:id → Eliminar (no self)" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="320" y="440" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="" value="&lt;b&gt;🏭 Suppliers (/suppliers)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="r1"><mxGeometry x="700" y="60" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="" value="GET / → Listar todos" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="700" y="100" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="" value="POST / → Crear proveedor" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="700" y="140" width="300" height="30" as="geometry" /></mxCell>
