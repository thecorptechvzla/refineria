        <mxCell id="" value="POST /register → Crear usuario" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="320" y="100" width="250" height="30" as="geometry" /></mxCell>
        <mxCell id="" value="POST /login → Login + Set-Cookie" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="320" y="140" width="250" height="30" as="geometry" /></mxCell>
        <mxCell id="" value="POST /logout → Borra cookie" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="320" y="180" width="250" height="30" as="geometry" /></mxCell>
        <mxCell id="" value="GET /profile → User actual (JWT)" style="whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="r1"><mxGeometry x="320" y="220" width="250" height="30" as="geometry" /></mxCell>
        <mxCell id="" value="&lt;b&gt;👥 Users (/users) — SOLO SUPERADMIN&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="r1"><mxGeometry x="320" y="280" width="300" height="30" as="geometry" /></mxCell>
