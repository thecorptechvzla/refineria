# ═══════════════════════════════════════════════════════════════════════════
# GOLDTRACK — BACKEND
# ═══════════════════════════════════════════════════════════════════════════
#
#  CÓMO USAR ESTE ARCHIVO:
#    1. Copiar como .env          cp .env.example .env
#    2. Ajustar valores locales   (solo BD local y secret)
#    3. Nunca editar este .example directamente con valores reales
#
#  LOCAL:  .env (gitignored) — valores para tu PC
#  PROD:   Vercel Dashboard > Settings > Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# ─── B A S E   D E   D A T O S ─────────────────────────────────────────────
# LOCAL: postgresql://postgres:postgres@localhost:5432/goldtrack?schema=public
# PROD:  Neon / Supabase (ej: postgresql://user:pass@ep-xxx.aws.neon.tech/goldtrack?sslmode=require)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/goldtrack?schema=public

# ─── J W T ─────────────────────────────────────────────────────────────────
# LOCAL: Cualquier string (no importa mientras sea consistente)
# PROD:  Generar con: openssl rand -hex 64
JWT_SECRET=goldtrack-dev-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── E N T O R N O ─────────────────────────────────────────────────────────
# LOCAL: development  |  PROD: production
NODE_ENV=development

# ─── P U E R T O ───────────────────────────────────────────────────────────
# LOCAL: 4000  |  PROD: Vercel lo asigna (no configurar)
PORT=4000

# ─── C O R S ───────────────────────────────────────────────────────────────
# LOCAL: http://localhost:3000
# PROD:  https://goldtrack.vercel.app (o dominio custom)
FRONTEND_URL=http://localhost:3000

# ─── F I L E   S T O R A G E ──────────────────────────────────────────────
# LOCAL: No necesario (usa disco local uploads/)
# PROD:  Token de Vercel Blob
# BLOB_READ_WRITE_TOKEN=
