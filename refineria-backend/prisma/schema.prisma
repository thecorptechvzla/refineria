generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERADMIN
}

enum TransactionType {
  IN
  OUT
}

enum WeightUnit {
  g
  kg
}

enum WorkerStatus {
  active
  inactive
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Supplier {
  id               String        @id @default(uuid())
  name             String
  contactInfo      String        @map("contact_info")
  registrationDate DateTime      @default(now()) @map("registration_date")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  transactions     Transaction[]

  @@map("suppliers")
}

model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  weight      Float
  weightUnit  WeightUnit      @map("weight_unit")
  purity      Float
  supplierId  String?         @map("supplier_id")
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  supplier    Supplier?       @relation(fields: [supplierId], references: [id])

  @@map("transactions")
}

enum ProcessStatus {
  open
  in_progress
  closed
}

model GoldBar {
  id               String   @id @default(uuid())
  code             String   @map("code")
  supplierId       String   @map("supplier_id")
  grossWeight      Float    @map("gross_weight")
  ley              Float?   @map("ley")
  analytical       Float    @map("analytical")
  expected         Float    @map("expected")
  recovered        Float    @map("recovered")
  available        Boolean  @default(true) @map("available")
  registrationDate DateTime @default(now()) @map("registration_date")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("gold_bars")
}

model Process {
  id         String        @id @default(uuid())
  number     Int           @map("number")
  supplierId String        @map("supplier_id")
  status     ProcessStatus @default(open)
  closedAt   DateTime?     @map("closed_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  lots       ProcessLot[]

  @@map("processes")
}

model ProcessLot {
  id           String   @id @default(uuid())
  processId    String   @map("process_id")
  number       Int      @map("number")
  barIds       String[] @map("bar_ids")
  recovered    Float?
  creationDate DateTime @default(now()) @map("creation_date")
  process      Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("process_lots")
}

model Worker {
  id        String       @id @default(uuid())
  name      String
  position  String
  status    WorkerStatus @default(active)
  startDate DateTime     @map("start_date")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("workers")
}
