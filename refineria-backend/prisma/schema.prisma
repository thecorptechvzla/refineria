generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Supplier {
  id               String        @id @default(uuid())
  name             String
  contactInfo      String        @map("contact_info")
  registrationDate DateTime      @default(now()) @map("registration_date")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  rif              String        @unique @map("rif")
  transactions     Transaction[]
  goldBars         GoldBar[]
  processes        Process[]

  @@map("suppliers")
}

model Transaction {
  id         String          @id @default(uuid())
  type       TransactionType
  weight     Float
  weightUnit WeightUnit      @map("weight_unit")
  purity     Float
  supplierId String?         @map("supplier_id")
  date       DateTime        @default(now())
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  supplier   Supplier?       @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model GoldBar {
  id               String   @id @default(uuid())
  code             String   @map("code")
  supplierId       String   @map("supplier_id")
  grossWeight      Float    @map("gross_weight")
  ley              Float?   @map("ley")
  analytical       Float    @map("analytical")
  expected         Float    @map("expected")
  recovered        Float    @map("recovered")
  leyAg            Float?   @map("ley_ag")
  analyticalAg     Float?   @map("analytical_ag")
  originalLot      String?  @map("original_lot")
  available        Boolean  @default(true) @map("available")
  registrationDate DateTime @default(now()) @map("registration_date")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  supplier         Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("gold_bars")
}

model Process {
  id              String        @id @default(uuid())
  number          String        @map("number")
  supplierId      String        @map("supplier_id")
  status          ProcessStatus @default(open)
  closedAt        DateTime?     @map("closed_at")
  actaRecepcion   String?       @map("acta_recepcion")
  actaFundicion   String?       @map("acta_fundicion")
  actaConformidad String?       @map("acta_conformidad")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  lots            ProcessLot[]
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("processes")
}

model ProcessLot {
  id           String   @id @default(uuid())
  processId    String   @map("process_id")
  barIds       String[] @map("bar_ids")
  creationDate DateTime @default(now()) @map("creation_date")
  number       Int      @map("number")
  recovered    Float?
  egresadoG    Float    @default(0) @map("egresado_g")
  process      Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@map("process_lots")
}

model Worker {
  id        String       @id @default(uuid())
  name      String
  position  String
  status    WorkerStatus @default(active)
  startDate DateTime     @map("start_date")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("workers")
}

model CustomFieldDefinition {
  id        String             @id @default(uuid())
  tableName String             @map("table_name")
  fieldName String             @map("field_name")
  fieldType String             @map("field_type")
  options   String?
  required  Boolean            @default(false)
  order     Int                @default(0)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  values    CustomFieldValue[]

  @@unique([tableName, fieldName])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id        String                @id @default(uuid())
  tableName String                @map("table_name")
  recordId  String                @map("record_id")
  fieldId   String                @map("field_id")
  value     String?
  field     CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([tableName, recordId, fieldId])
  @@index([tableName, recordId])
  @@map("custom_field_values")
}

model ProcessCounter {
  supplierId String @id @map("supplier_id")
  seq        Int    @default(0)

  @@map("process_counters")
}

model SupplyItem {
  id            String              @id @default(uuid())
  code          String              @unique
  name          String
  category      SupplyCategory
  unit          String              @default("UNIDAD")
  currentStock  Int                 @default(0)
  criticalLevel Int                 @default(1)
  isCritical    Boolean             @default(false) @map("is_critical")
  criticalType  CriticalType?       @map("critical_type")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  transactions  SupplyTransaction[]

  @@map("supply_items")
}

model SupplyTransaction {
  id        String                @id @default(uuid())
  itemId    String                @map("item_id")
  type      SupplyTransactionType
  quantity  Int
  date      DateTime              @default(now())
  reference String?
  item      SupplyItem            @relation(fields: [itemId], references: [id])

  @@map("supply_transactions")
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

enum Role {
  ADMIN
  SUPERADMIN
  OWNER
}

enum TransactionType {
  IN
  OUT
}

enum WeightUnit {
  g
  kg
}

enum WorkerStatus {
  active
  inactive
}

enum SupplyCategory {
  OPERATIONS
  GENERAL_SERVICES
  CRITICAL
}

enum CriticalType {
  QUIMICO
  GAS
  COMBUSTIBLE
}

enum SupplyTransactionType {
  IN
  OUT
}

enum ProcessStatus {
  open
  closed
  in_progress
}
